# Public backend URL used by client components
NEXT_PUBLIC_BACKEND_URL=https://eduverse-4x8o.onrender.com

# Optional server-only override used by Next API routes
# If omitted, server routes fall back to NEXT_PUBLIC_BACKEND_URL.
BACKEND_URL=https://eduverse-4x8o.onrender.com

# Optional cookie name used by frontend auth routes to hold backend OAuth state.
# Keep in sync with backend SessionMiddleware cookie name if customized.
BFF_BACKEND_SESSION_COOKIE_NAME=session

# Auth integration notes:
# - Browser auth is cookie-based (HttpOnly access/refresh cookies from backend)
# - CSRF header is generated client-side from CSRF cookie for mutating requests
# - Keep BACKEND_URL and NEXT_PUBLIC_BACKEND_URL on the same backend origin
# - Set backend GOOGLE_REDIRECT_URI to: https://<frontend-domain>/api/auth/callback
